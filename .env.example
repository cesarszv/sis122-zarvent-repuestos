# Database connection
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=sis122_zarvent_repuestos
DB_USER=zarvent_app
DB_PASSWORD=change_me

# Flask
FLASK_SECRET_KEY=zarvent-academic-secret-key-122

# SQL Trace (opt-in diagnostic module, see spec/sql-trace/SPEC.md).
# Set to 1 to capture live SQL statements in /sql-trace and stdout.
# Default (0) keeps CRUD paths overhead-free; passwords are redacted either way.
SQL_TRACE_ENABLED=0

# Application logging level. Use DEBUG during defense demos to inspect CRUD flow.
LOG_LEVEL=INFO
