{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flask: Run (debug)",
      "type": "debugpy",
      "request": "launch",
      "module": "flask",
      "env": {
        "FLASK_DEBUG": "1",
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "args": [
        "--app",
        "zarvent_repuestos.web.app:app",
        "run",
        "--debug"
      ],
      "jinja": true,
      "justMyCode": true,
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Flask: Run with SQL Trace",
      "type": "debugpy",
      "request": "launch",
      "module": "flask",
      "env": {
        "FLASK_DEBUG": "1",
        "SQL_TRACE_ENABLED": "1",
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "args": [
        "--app",
        "zarvent_repuestos.web.app:app",
        "run",
        "--host",
        "127.0.0.1",
        "--port",
        "5000",
        "--no-debugger",
        "--no-reload"
      ],
      "jinja": true,
      "justMyCode": true,
      "cwd": "${workspaceFolder}"
    }
  ]
}
