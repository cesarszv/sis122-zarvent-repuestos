# Zarvent Repuestos - variables de entorno para Docker Compose.
#
# Este archivo es una PLANTILLA. Para personalizar los valores, copia
# este archivo a `.env` y modifica lo que necesites. Docker Compose lee
# automaticamente el `.env` que esta al lado del `docker-compose.yml`.
#
# cp .env.example .env

# -----------------------------------------------------------------------------
# MySQL
# -----------------------------------------------------------------------------
# Password del usuario root del contenedor. Es solo para administracion
# interna de MySQL. La app no usa este usuario.
MYSQL_ROOT_PASSWORD=root_change_me

# Puerto del host donde MySQL queda accesible desde Windows. Por
# defecto `3307` para no chocar con un MySQL local que pueda estar en
# `3306`. DataGrip se conecta a este puerto.
MYSQL_HOST_PORT=3307

# -----------------------------------------------------------------------------
# Aplicacion Flask (contenedor `web`)
# -----------------------------------------------------------------------------
# Host de MySQL desde el contenedor `web`. Es el nombre del servicio
# definido en `docker-compose.yml`. NO usar `127.0.0.1` ni `localhost`
# porque el contenedor se apunta a si mismo.
DB_HOST=mysql
DB_PORT=3306
DB_NAME=sis122_zarvent_repuestos
DB_USER=zarvent_app
DB_PASSWORD=change_me

# Clave de sesion de Flask. Cambiala si tu defensa lo amerita.
FLASK_SECRET_KEY=zarvent-academic-secret-key-122

# Puerto del host donde la web queda accesible desde el navegador.
WEB_HOST_PORT=5000

# -----------------------------------------------------------------------------
# Diagnostico (opcional)
# -----------------------------------------------------------------------------
# Trazador SQL: 0 = apagado, 1 = encendido. Ver /sql-trace.
SQL_TRACE_ENABLED=0
LOG_LEVEL=INFO

# Tiempo maximo que el contenedor `web` espera a que MySQL este listo.
WAIT_FOR_MYSQL_TIMEOUT_SECONDS=120
WAIT_FOR_MYSQL_INTERVAL_SECONDS=2
